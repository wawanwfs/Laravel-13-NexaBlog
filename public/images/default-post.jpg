<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 450">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#6366f1;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#ec4899;stop-opacity:1" />
    </linearGradient>
  </defs>
  <rect width="800" height="450" fill="url(#bg)"/>
  <rect x="50" y="80" width="700" height="290" rx="20" fill="rgba(255,255,255,0.1)"/>
  <text x="400" y="210" font-family="Georgia, serif" font-size="72" fill="white" text-anchor="middle">📰</text>
  <text x="400" y="280" font-family="Georgia, serif" font-size="28" font-weight="bold" fill="white" text-anchor="middle">NexaBlog</text>
  <text x="400" y="315" font-family="Arial, sans-serif" font-size="16" fill="rgba(255,255,255,0.8)" text-anchor="middle">Platform Blog Modern</text>
</svg>
